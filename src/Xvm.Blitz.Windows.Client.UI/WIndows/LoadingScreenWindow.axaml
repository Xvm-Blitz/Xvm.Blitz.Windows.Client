<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Xvm.Blitz.Windows.Client.UI.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="600" d:DesignHeight="500"
        x:Class="Xvm.Blitz.Windows.Client.UI.Windows.LoadingScreenWindow"
        x:DataType="vm:LoadingScreenViewModel"
        Icon="/Assets/xvm.ico"
        Title="Настройка экрана загрузки боя"
        Width="600" Height="500"
        WindowStartupLocation="CenterScreen"
        CanResize="False">

    <Grid RowDefinitions="Auto,*,Auto" Margin="20">
        <TextBlock Grid.Row="0" Text="Настройка экрана загрузки боя"
                   FontWeight="Bold" FontSize="{DynamicResource MainTitleFontSize}"
                   HorizontalAlignment="Center" Margin="0,0,0,20" />

        <StackPanel Grid.Row="1" Spacing="15">
            <TextBlock Text="Укажите путь к папке с игрой Tanks Blitz:"
                       FontSize="{DynamicResource NormalFontSize}"
                       TextWrapping="Wrap" />

            <Grid ColumnDefinitions="*,Auto" MinWidth="200">
                <TextBox Grid.Column="0"
                         Text="{Binding GamePath}"
                         Margin="0,0,10,0"
                         FontSize="{DynamicResource NormalFontSize}"
                         ToolTip.Tip="{Binding GamePath}" />
                <Button Grid.Column="1" Content="..." Command="{Binding SelectGamePathCommand}"
                        FontSize="{DynamicResource NormalFontSize}" />
            </Grid>

                        <Border BorderThickness="1" BorderBrush="Gray" CornerRadius="5" Padding="10" Margin="0,10,0,0">
                <StackPanel Spacing="10">
                    <TextBlock Text="Доступные действия:" FontWeight="Bold" FontSize="{DynamicResource SubHeaderFontSize}" />
                    <TextBlock Text="• Заменить - заменит стандартные файлы экрана загрузки"
                               FontSize="{DynamicResource NormalFontSize}" TextWrapping="Wrap" />
                    <TextBlock Text="• Вернуть исходное состояние - восстановит изначально замененные файлы"
                               FontSize="{DynamicResource NormalFontSize}" TextWrapping="Wrap" />
                </StackPanel>
            </Border>

            <TextBlock Text="{Binding Message}"
                       IsVisible="{Binding Message, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                       Foreground="{Binding IsError, Converter={StaticResource ErrorToColorConverter}}"
                       FontSize="{DynamicResource NormalFontSize}"
                       TextWrapping="Wrap"
                       Margin="0,10,0,0"
                       HorizontalAlignment="Center" />
        </StackPanel>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0" Spacing="10">
            <Button Content="Заменить" Command="{Binding ReplaceFilesCommand}"
                    MinWidth="100" MinHeight="30" Padding="15,5"
                    Background="{DynamicResource ButtonGreen}"
                    Foreground="{DynamicResource ButtonGreenText}"
                    FontSize="{DynamicResource SectionHeaderFontSize}"
                    HorizontalContentAlignment="Center">
                <Button.Styles>
                    <Style Selector="Button:pointerover">
                        <Setter Property="Background" Value="{DynamicResource ButtonGreenHover}" />
                    </Style>
                    <Style Selector="Button:pressed">
                        <Setter Property="Background" Value="{DynamicResource ButtonGreenPressed}" />
                    </Style>
                </Button.Styles>
            </Button>
            <Button Content="Вернуть исходные файлы" Command="{Binding RestoreFilesCommand}"
                    MinWidth="100" MinHeight="30" Padding="15,5"
                    Background="{DynamicResource ButtonGreen}"
                    Foreground="{DynamicResource ButtonGreenText}"
                    FontSize="{DynamicResource SectionHeaderFontSize}"
                    HorizontalContentAlignment="Center">
                <Button.Styles>
                    <Style Selector="Button:pointerover">
                        <Setter Property="Background" Value="{DynamicResource ButtonOrangeHover}" />
                    </Style>
                    <Style Selector="Button:pressed">
                        <Setter Property="Background" Value="{DynamicResource ButtonOrangePressed}" />
                    </Style>
                </Button.Styles>
            </Button>
            <Button Content="Закрыть" Command="{Binding CloseCommand}"
                    MinWidth="100" MinHeight="30" Padding="15,5"
                    Background="{DynamicResource ButtonRed}"
                    Foreground="{DynamicResource ButtonRedText}"
                    FontSize="{DynamicResource SectionHeaderFontSize}"
                    HorizontalContentAlignment="Center">
                <Button.Styles>
                    <Style Selector="Button:pointerover">
                        <Setter Property="Background" Value="{DynamicResource ButtonRedHover}" />
                    </Style>
                    <Style Selector="Button:pressed">
                        <Setter Property="Background" Value="{DynamicResource ButtonRedPressed}" />
                    </Style>
                </Button.Styles>
            </Button>
        </StackPanel>
    </Grid>
</Window>
