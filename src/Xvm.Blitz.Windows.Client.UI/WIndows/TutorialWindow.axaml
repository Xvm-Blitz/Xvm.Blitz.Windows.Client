<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Xvm.Blitz.Windows.Client.UI.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="720" d:DesignHeight="560"
        x:Class="Xvm.Blitz.Windows.Client.UI.Windows.TutorialWindow"
        x:DataType="vm:TutorialViewModel"
        Icon="/Assets/xvm.ico"
        Title="Обучение — XVM Blitz"
        Width="720" Height="580"
        MinWidth="640" MinHeight="520"
        WindowStartupLocation="CenterOwner"
        CanResize="True">

    <Grid Margin="24" RowDefinitions="Auto,Auto,*,Auto">
        <Grid Grid.Row="0" ColumnDefinitions="*,Auto" Margin="0,0,0,12">
            <StackPanel Grid.Column="0" Spacing="6">
                <TextBlock Text="Обучение"
                           FontSize="{DynamicResource MainTitleFontSize}"
                           FontWeight="Bold" />
                <TextBlock Text="{Binding StepProgressText}"
                           Opacity="0.7"
                           FontSize="{DynamicResource NormalFontSize}" />
            </StackPanel>
            <Button Grid.Column="1"
                    Content="Пропустить"
                    Command="{Binding SkipCommand}"
                    VerticalAlignment="Top"
                    MinWidth="120"
                    MinHeight="34"
                    Padding="16,8"
                    FontSize="{DynamicResource SectionHeaderFontSize}"
                    HorizontalContentAlignment="Center"
                    VerticalContentAlignment="Center" />
        </Grid>

        <ProgressBar Grid.Row="1"
                     Minimum="0"
                     Maximum="1"
                     Value="{Binding ProgressRatio}"
                     Height="4"
                     Foreground="#4CAF50" />

        <Border Grid.Row="2"
                Background="#1AFFFFFF"
                CornerRadius="12"
                Padding="24"
                Margin="0,16,0,16"
                ClipToBounds="True">
            <Border.RenderTransform>
                <TranslateTransform Y="{Binding ContentOffsetY}" />
            </Border.RenderTransform>
            <Border.Transitions>
                <Transitions>
                    <DoubleTransition Property="Opacity" Duration="0:0:0.18" Easing="CubicEaseOut" />
                </Transitions>
            </Border.Transitions>
            <Border.Opacity>
                <Binding Path="ContentOpacity" />
            </Border.Opacity>

            <Grid ColumnDefinitions="1.1*,0.9*" ColumnSpacing="24">
                <ScrollViewer Grid.Column="0"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <StackPanel Spacing="14">
                        <TextBlock Text="{Binding CurrentStep.Title}"
                                   FontSize="22"
                                   FontWeight="Bold"
                                   TextWrapping="Wrap" />
                        <TextBlock Text="{Binding CurrentStep.Description}"
                                   FontSize="{DynamicResource NormalFontSize}"
                                   Opacity="0.9"
                                   TextWrapping="Wrap"
                                   LineHeight="22" />
                        <ItemsControl ItemsSource="{Binding CurrentStep.Highlights}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="x:String">
                                    <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,4,0,0">
                                        <Ellipse Width="7" Height="7" Fill="#4CAF50" VerticalAlignment="Top" Margin="0,6,0,0" />
                                        <TextBlock Text="{Binding}"
                                                   FontSize="{DynamicResource NormalFontSize}"
                                                   TextWrapping="Wrap" />
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <Border Background="#334CAF50"
                                CornerRadius="8"
                                Padding="12,10"
                                Margin="0,4,0,0">
                            <TextBlock Text="{Binding CurrentStep.Tip}"
                                       FontSize="{DynamicResource SmallNoteFontSize}"
                                       TextWrapping="Wrap"
                                       LineHeight="18" />
                        </Border>
                    </StackPanel>
                </ScrollViewer>

                <Border Grid.Column="1"
                        Background="#14000000"
                        CornerRadius="10"
                        Padding="16"
                        ClipToBounds="True">
                    <Panel>
                        <Panel IsVisible="{Binding IsWelcomeVisible}">
                            <Panel.Styles>
                                <Style Selector="Panel">
                                    <Style.Animations>
                                        <Animation Duration="0:0:2.4" IterationCount="Infinite">
                                            <KeyFrame Cue="0%">
                                                <Setter Property="Opacity" Value="0.75" />
                                            </KeyFrame>
                                            <KeyFrame Cue="50%">
                                                <Setter Property="Opacity" Value="1" />
                                            </KeyFrame>
                                            <KeyFrame Cue="100%">
                                                <Setter Property="Opacity" Value="0.75" />
                                            </KeyFrame>
                                        </Animation>
                                    </Style.Animations>
                                </Style>
                            </Panel.Styles>
                            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="16">
                                <Border Width="88" Height="88" CornerRadius="22" Background="#334CAF50">
                                    <TextBlock Text="XVM"
                                               FontWeight="Bold"
                                               FontSize="22"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               Foreground="#81C784" />
                                </Border>
                                <TextBlock Text="Статистика в бою"
                                           HorizontalAlignment="Center"
                                           FontWeight="SemiBold"
                                           FontSize="{DynamicResource SubHeaderFontSize}" />
                                <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center">
                                    <Border Width="70" Height="36" CornerRadius="6" Background="#664CAF50" />
                                    <Border Width="70" Height="36" CornerRadius="6" Background="#66E57373" />
                                </StackPanel>
                            </StackPanel>
                        </Panel>

                        <Panel IsVisible="{Binding IsAuthorizationVisible}">
                            <StackPanel VerticalAlignment="Center" Spacing="12">
                                <TextBlock Text="API-ключ"
                                           FontWeight="SemiBold"
                                           HorizontalAlignment="Center" />
                                <Border Background="#22FFFFFF" CornerRadius="6" Padding="12,10">
                                    <TextBlock Text="••••••••••••••••"
                                               Opacity="0.7"
                                               HorizontalAlignment="Center" />
                                </Border>
                                <Border Background="#4CAF50"
                                        CornerRadius="6"
                                        Padding="12,10"
                                        HorizontalAlignment="Stretch">
                                    <Border.Styles>
                                        <Style Selector="Border">
                                            <Style.Animations>
                                                <Animation Duration="0:0:1.8" IterationCount="Infinite">
                                                    <KeyFrame Cue="0%">
                                                        <Setter Property="Opacity" Value="0.85" />
                                                    </KeyFrame>
                                                    <KeyFrame Cue="50%">
                                                        <Setter Property="Opacity" Value="1" />
                                                    </KeyFrame>
                                                    <KeyFrame Cue="100%">
                                                        <Setter Property="Opacity" Value="0.85" />
                                                    </KeyFrame>
                                                </Animation>
                                            </Style.Animations>
                                        </Style>
                                    </Border.Styles>
                                    <TextBlock Text="Войти"
                                               Foreground="White"
                                               HorizontalAlignment="Center"
                                               FontWeight="SemiBold" />
                                </Border>
                                <Border Background="#22000000" CornerRadius="6" Padding="10" Margin="0,8,0,0">
                                    <StackPanel Spacing="6">
                                        <TextBlock Text="Квота: 72%" FontSize="12" Opacity="0.8" />
                                        <ProgressBar Value="72" Maximum="100" Height="6" Foreground="#4CAF50" />
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Panel>

                        <Panel IsVisible="{Binding IsBattleSessionsVisible}">
                            <StackPanel VerticalAlignment="Center" Spacing="12">
                                <TextBlock Text="Сессия боя"
                                           FontWeight="SemiBold"
                                           HorizontalAlignment="Center" />
                                <Border Background="#22FFFFFF" CornerRadius="6" Padding="12,10">
                                    <StackPanel Spacing="6">
                                        <TextBlock Text="Никнейм" Opacity="0.7" FontSize="12" />
                                        <TextBlock Text="PlayerName" FontWeight="SemiBold" />
                                    </StackPanel>
                                </Border>
                                <Border Background="#22FFFFFF" CornerRadius="6" Padding="12,10">
                                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                                        <StackPanel Spacing="6">
                                            <TextBlock Text="Секретный ключ" Opacity="0.7" FontSize="12" />
                                            <TextBlock Text="••••••••••••" Opacity="0.8" />
                                        </StackPanel>
                                        <Border Grid.Column="1"
                                                Background="#FF9800"
                                                CornerRadius="6"
                                                Padding="10,8"
                                                VerticalAlignment="Center">
                                            <TextBlock Text="Сгенерировать"
                                                       Foreground="White"
                                                       FontSize="11"
                                                       FontWeight="SemiBold" />
                                        </Border>
                                    </Grid>
                                </Border>
                                <Border Background="#4CAF50" CornerRadius="6" Padding="12,10">
                                    <Border.Styles>
                                        <Style Selector="Border">
                                            <Style.Animations>
                                                <Animation Duration="0:0:1.8" IterationCount="Infinite">
                                                    <KeyFrame Cue="0%">
                                                        <Setter Property="Opacity" Value="0.85" />
                                                    </KeyFrame>
                                                    <KeyFrame Cue="50%">
                                                        <Setter Property="Opacity" Value="1" />
                                                    </KeyFrame>
                                                    <KeyFrame Cue="100%">
                                                        <Setter Property="Opacity" Value="0.85" />
                                                    </KeyFrame>
                                                </Animation>
                                            </Style.Animations>
                                        </Style>
                                    </Border.Styles>
                                    <TextBlock Text="Начать сессию"
                                               Foreground="White"
                                               HorizontalAlignment="Center"
                                               FontWeight="SemiBold" />
                                </Border>
                                <Border Background="#33FF9800" BorderBrush="Orange" BorderThickness="1" CornerRadius="6" Padding="10">
                                    <TextBlock Text="Не дольше 24 часов"
                                               Foreground="Orange"
                                               FontSize="12"
                                               TextWrapping="Wrap"
                                               HorizontalAlignment="Center" />
                                </Border>
                            </StackPanel>
                        </Panel>

                        <Panel IsVisible="{Binding IsSecretKeyVisible}">
                            <StackPanel VerticalAlignment="Center" Spacing="12">
                                <TextBlock Text="Секретный ключ"
                                           FontWeight="SemiBold"
                                           HorizontalAlignment="Center" />
                                <Border Background="#22FFFFFF" CornerRadius="6" Padding="12,10">
                                    <StackPanel Spacing="8">
                                        <TextBlock Text="Один ключ — общая история"
                                                   FontWeight="SemiBold"
                                                   HorizontalAlignment="Center" />
                                        <StackPanel Spacing="6">
                                            <Border Background="#22000000"
                                                    CornerRadius="6"
                                                    Padding="10,8"
                                                    HorizontalAlignment="Stretch">
                                                <TextBlock Text="ПК · a1b2c3…"
                                                           FontSize="12"
                                                           HorizontalAlignment="Center" />
                                            </Border>
                                            <TextBlock Text="⇅"
                                                       FontSize="14"
                                                       Opacity="0.5"
                                                       HorizontalAlignment="Center" />
                                            <Border Background="#22000000"
                                                    CornerRadius="6"
                                                    Padding="10,8"
                                                    HorizontalAlignment="Stretch">
                                                <TextBlock Text="Другое устройство · a1b2c3…"
                                                           FontSize="12"
                                                           TextWrapping="Wrap"
                                                           TextAlignment="Center"
                                                           HorizontalAlignment="Stretch" />
                                            </Border>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                                <Border Background="#FF9800" CornerRadius="6" Padding="12,10">
                                    <TextBlock Text="Сгенерировать"
                                               Foreground="White"
                                               HorizontalAlignment="Center"
                                               FontWeight="SemiBold" />
                                </Border>
                                <TextBlock Text="Не нужна синхронизация — достаточно случайного ключа"
                                           FontSize="12"
                                           Opacity="0.75"
                                           TextWrapping="Wrap"
                                           HorizontalAlignment="Center" />
                            </StackPanel>
                        </Panel>

                        <Panel IsVisible="{Binding IsLoadingScreenVisible}">
                            <StackPanel VerticalAlignment="Center" Spacing="12">
                                <Border Background="#22FFFFFF" CornerRadius="8" Padding="12">
                                    <StackPanel Spacing="8">
                                        <TextBlock Text="Tanks Blitz" FontWeight="SemiBold" />
                                        <TextBlock Text="C:\Games\TanksBlitz" Opacity="0.65" FontSize="12" TextTrimming="CharacterEllipsis" />
                                    </StackPanel>
                                </Border>
                                <Border Background="#4CAF50" CornerRadius="6" Padding="12,10">
                                    <Border.Styles>
                                        <Style Selector="Border">
                                            <Style.Animations>
                                                <Animation Duration="0:0:1.6" IterationCount="Infinite">
                                                    <KeyFrame Cue="0%">
                                                        <Setter Property="Opacity" Value="0.8" />
                                                    </KeyFrame>
                                                    <KeyFrame Cue="50%">
                                                        <Setter Property="Opacity" Value="1" />
                                                    </KeyFrame>
                                                    <KeyFrame Cue="100%">
                                                        <Setter Property="Opacity" Value="0.8" />
                                                    </KeyFrame>
                                                </Animation>
                                            </Style.Animations>
                                        </Style>
                                    </Border.Styles>
                                    <TextBlock Text="Заменить"
                                               Foreground="White"
                                               HorizontalAlignment="Center"
                                               FontWeight="SemiBold" />
                                </Border>
                                <Border Background="#33FF9800" BorderBrush="Orange" BorderThickness="1" CornerRadius="6" Padding="10">
                                    <TextBlock Text="Требуется замена экрана"
                                               Foreground="Orange"
                                               FontSize="12"
                                               TextWrapping="Wrap"
                                               HorizontalAlignment="Center" />
                                </Border>
                            </StackPanel>
                        </Panel>

                        <Panel IsVisible="{Binding IsReplaysVisible}">
                            <StackPanel VerticalAlignment="Center" Spacing="12">
                                <TextBlock Text="Реплеи" FontWeight="SemiBold" HorizontalAlignment="Center" />
                                <Border Background="#22FFFFFF" CornerRadius="6" Padding="10">
                                    <Grid ColumnDefinitions="*,Auto">
                                        <TextBlock Grid.Column="0"
                                                   Text="...\TanksBlitz\replays"
                                                   Opacity="0.75"
                                                   VerticalAlignment="Center"
                                                   TextTrimming="CharacterEllipsis" />
                                        <Border Grid.Column="1" Background="#334CAF50" CornerRadius="4" Padding="10,4" Margin="8,0,0,0">
                                            <TextBlock Text="..." FontWeight="Bold" />
                                        </Border>
                                    </Grid>
                                </Border>
                                <StackPanel Spacing="6">
                                    <Border Height="10" CornerRadius="3" Background="#334CAF50" Width="180" HorizontalAlignment="Left">
                                        <Border.Styles>
                                            <Style Selector="Border">
                                                <Style.Animations>
                                                    <Animation Duration="0:0:2" IterationCount="Infinite">
                                                        <KeyFrame Cue="0%">
                                                            <Setter Property="Opacity" Value="0.35" />
                                                        </KeyFrame>
                                                        <KeyFrame Cue="40%">
                                                            <Setter Property="Opacity" Value="1" />
                                                        </KeyFrame>
                                                        <KeyFrame Cue="100%">
                                                            <Setter Property="Opacity" Value="0.35" />
                                                        </KeyFrame>
                                                    </Animation>
                                                </Style.Animations>
                                            </Style>
                                        </Border.Styles>
                                    </Border>
                                    <TextBlock Text="Новый реплей обнаружен"
                                               FontSize="12"
                                               Opacity="0.75"
                                               HorizontalAlignment="Left" />
                                </StackPanel>
                            </StackPanel>
                        </Panel>

                        <Panel IsVisible="{Binding IsOverlaysVisible}">
                            <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                                <Border Grid.Column="0" Background="#264CAF50" CornerRadius="8" Padding="8">
                                    <Border.Styles>
                                        <Style Selector="Border">
                                            <Style.Animations>
                                                <Animation Duration="0:0:2.2" IterationCount="Infinite">
                                                    <KeyFrame Cue="0%">
                                                        <Setter Property="Opacity" Value="0.7" />
                                                    </KeyFrame>
                                                    <KeyFrame Cue="50%">
                                                        <Setter Property="Opacity" Value="1" />
                                                    </KeyFrame>
                                                    <KeyFrame Cue="100%">
                                                        <Setter Property="Opacity" Value="0.7" />
                                                    </KeyFrame>
                                                </Animation>
                                            </Style.Animations>
                                        </Style>
                                    </Border.Styles>
                                    <StackPanel Spacing="6">
                                        <TextBlock Text="Союзники" Foreground="#81C784" FontWeight="Bold" FontSize="12" HorizontalAlignment="Center" />
                                        <Border Height="18" CornerRadius="3" Background="#334CAF50" />
                                        <Border Height="18" CornerRadius="3" Background="#334CAF50" />
                                        <Border Height="18" CornerRadius="3" Background="#334CAF50" />
                                    </StackPanel>
                                </Border>
                                <Border Grid.Column="1" Background="#26E57373" CornerRadius="8" Padding="8">
                                    <Border.Styles>
                                        <Style Selector="Border">
                                            <Style.Animations>
                                                <Animation Duration="0:0:2.2" Delay="0:0:0.3" IterationCount="Infinite">
                                                    <KeyFrame Cue="0%">
                                                        <Setter Property="Opacity" Value="0.7" />
                                                    </KeyFrame>
                                                    <KeyFrame Cue="50%">
                                                        <Setter Property="Opacity" Value="1" />
                                                    </KeyFrame>
                                                    <KeyFrame Cue="100%">
                                                        <Setter Property="Opacity" Value="0.7" />
                                                    </KeyFrame>
                                                </Animation>
                                            </Style.Animations>
                                        </Style>
                                    </Border.Styles>
                                    <StackPanel Spacing="6">
                                        <TextBlock Text="Противники" Foreground="#EF9A9A" FontWeight="Bold" FontSize="12" HorizontalAlignment="Center" />
                                        <Border Height="18" CornerRadius="3" Background="#33E57373" />
                                        <Border Height="18" CornerRadius="3" Background="#33E57373" />
                                        <Border Height="18" CornerRadius="3" Background="#33E57373" />
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </Panel>

                        <Panel IsVisible="{Binding IsHidePanelsVisible}">
                            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="14">
                                <Border Width="220"
                                        Height="110"
                                        CornerRadius="8"
                                        Background="#33000000"
                                        BorderBrush="#664F77C7"
                                        BorderThickness="1"
                                        Padding="12">
                                    <StackPanel Spacing="8" VerticalAlignment="Center">
                                        <Border Height="18" CornerRadius="3" Background="#334F77C7" />
                                        <Border Height="18" CornerRadius="3" Background="#334F77C7" Width="160" HorizontalAlignment="Left" />
                                        <Border Height="18" CornerRadius="3" Background="#334F77C7" Width="140" HorizontalAlignment="Left" />
                                    </StackPanel>
                                </Border>
                                <Border Background="#2D2D30"
                                        BorderBrush="#3F3F46"
                                        BorderThickness="1"
                                        CornerRadius="6"
                                        Padding="12,8"
                                        HorizontalAlignment="Center">
                                    <Border.Styles>
                                        <Style Selector="Border">
                                            <Style.Animations>
                                                <Animation Duration="0:0:1.8" IterationCount="Infinite">
                                                    <KeyFrame Cue="0%">
                                                        <Setter Property="Opacity" Value="0.55" />
                                                    </KeyFrame>
                                                    <KeyFrame Cue="40%">
                                                        <Setter Property="Opacity" Value="1" />
                                                    </KeyFrame>
                                                    <KeyFrame Cue="100%">
                                                        <Setter Property="Opacity" Value="0.55" />
                                                    </KeyFrame>
                                                </Animation>
                                            </Style.Animations>
                                        </Style>
                                    </Border.Styles>
                                    <TextBlock Text="Скрыть панели"
                                               FontWeight="SemiBold"
                                               Foreground="#90CAF9"
                                               HorizontalAlignment="Center" />
                                </Border>
                                <TextBlock Text="Правый клик по панели"
                                           Opacity="0.75"
                                           HorizontalAlignment="Center"
                                           FontSize="12" />
                            </StackPanel>
                        </Panel>

                        <Panel IsVisible="{Binding IsTrayVisible}">
                            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="12">
                                <Border Width="220" Height="120" CornerRadius="8" Background="#22000000" Padding="10">
                                    <DockPanel LastChildFill="False">
                                        <Border DockPanel.Dock="Bottom"
                                                Background="#33000000"
                                                CornerRadius="6"
                                                Padding="8"
                                                HorizontalAlignment="Right">
                                            <Border.Styles>
                                                <Style Selector="Border">
                                                    <Style.Animations>
                                                        <Animation Duration="0:0:2" IterationCount="Infinite">
                                                            <KeyFrame Cue="0%">
                                                                <Setter Property="Opacity" Value="0.5" />
                                                            </KeyFrame>
                                                            <KeyFrame Cue="50%">
                                                                <Setter Property="Opacity" Value="1" />
                                                            </KeyFrame>
                                                            <KeyFrame Cue="100%">
                                                                <Setter Property="Opacity" Value="0.5" />
                                                            </KeyFrame>
                                                        </Animation>
                                                    </Style.Animations>
                                                </Style>
                                            </Border.Styles>
                                            <StackPanel Spacing="4">
                                                <TextBlock Text="XVM Blitz" FontSize="11" FontWeight="SemiBold" />
                                                <TextBlock Text="Показать" FontSize="11" Opacity="0.8" />
                                                <TextBlock Text="Выход" FontSize="11" Opacity="0.8" />
                                            </StackPanel>
                                        </Border>
                                    </DockPanel>
                                </Border>
                                <TextBlock Text="Работа в системном трее"
                                           Opacity="0.75"
                                           FontSize="12"
                                           HorizontalAlignment="Center" />
                            </StackPanel>
                        </Panel>

                        <Panel IsVisible="{Binding IsUpdatesVisible}">
                            <StackPanel VerticalAlignment="Center" Spacing="12">
                                <TextBlock Text="Обновление" FontWeight="SemiBold" HorizontalAlignment="Center" />
                                <TextBlock Text="Текущая версия: 1.1.0"
                                           Opacity="0.8"
                                           HorizontalAlignment="Center"
                                           FontSize="12" />
                                <Border Background="#33FF9800" BorderBrush="Orange" BorderThickness="1" CornerRadius="8" Padding="12">
                                    <Border.Styles>
                                        <Style Selector="Border">
                                            <Style.Animations>
                                                <Animation Duration="0:0:1.8" IterationCount="Infinite">
                                                    <KeyFrame Cue="0%">
                                                        <Setter Property="Opacity" Value="0.7" />
                                                    </KeyFrame>
                                                    <KeyFrame Cue="50%">
                                                        <Setter Property="Opacity" Value="1" />
                                                    </KeyFrame>
                                                    <KeyFrame Cue="100%">
                                                        <Setter Property="Opacity" Value="0.7" />
                                                    </KeyFrame>
                                                </Animation>
                                            </Style.Animations>
                                        </Style>
                                    </Border.Styles>
                                    <StackPanel Spacing="4">
                                        <TextBlock Text="Доступна новая версия"
                                                   Foreground="Orange"
                                                   FontWeight="Bold"
                                                   FontSize="12"
                                                   HorizontalAlignment="Center" />
                                        <TextBlock Text="Последняя: 1.2.0"
                                                   FontSize="12"
                                                   HorizontalAlignment="Center"
                                                   Opacity="0.85" />
                                    </StackPanel>
                                </Border>
                                <Border Background="#4CAF50" CornerRadius="6" Padding="12,8" HorizontalAlignment="Center">
                                    <TextBlock Text="Скачать" Foreground="White" FontWeight="SemiBold" />
                                </Border>
                            </StackPanel>
                        </Panel>

                        <Panel IsVisible="{Binding IsBattleFlowVisible}">
                            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Stretch" Spacing="8">
                                <Border Background="#334CAF50" CornerRadius="6" Padding="10,8" HorizontalAlignment="Stretch">
                                    <TextBlock Text="Реплей"
                                               FontSize="12"
                                               FontWeight="SemiBold"
                                               HorizontalAlignment="Center" />
                                </Border>
                                <TextBlock Text="↓"
                                           Opacity="0.6"
                                           FontSize="14"
                                           HorizontalAlignment="Center" />
                                <Border Background="#334F77C7" CornerRadius="6" Padding="10,8" HorizontalAlignment="Stretch">
                                    <TextBlock Text="Захват боя"
                                               FontSize="12"
                                               FontWeight="SemiBold"
                                               HorizontalAlignment="Center" />
                                </Border>
                                <TextBlock Text="↓"
                                           Opacity="0.6"
                                           FontSize="14"
                                           HorizontalAlignment="Center" />
                                <Border Background="#33FFB74D" CornerRadius="6" Padding="10,8" HorizontalAlignment="Stretch">
                                    <TextBlock Text="API"
                                               FontSize="12"
                                               FontWeight="SemiBold"
                                               HorizontalAlignment="Center" />
                                </Border>
                                <TextBlock Text="↓"
                                           Opacity="0.6"
                                           FontSize="14"
                                           HorizontalAlignment="Center" />
                                <Border Background="#264CAF50" CornerRadius="8" Padding="10,8" HorizontalAlignment="Stretch">
                                    <Border.Styles>
                                        <Style Selector="Border">
                                            <Style.Animations>
                                                <Animation Duration="0:0:1.8" IterationCount="Infinite">
                                                    <KeyFrame Cue="0%">
                                                        <Setter Property="Opacity" Value="0.55" />
                                                    </KeyFrame>
                                                    <KeyFrame Cue="50%">
                                                        <Setter Property="Opacity" Value="1" />
                                                    </KeyFrame>
                                                    <KeyFrame Cue="100%">
                                                        <Setter Property="Opacity" Value="0.55" />
                                                    </KeyFrame>
                                                </Animation>
                                            </Style.Animations>
                                        </Style>
                                    </Border.Styles>
                                    <TextBlock Text="Окна статистики"
                                               HorizontalAlignment="Center"
                                               FontSize="12"
                                               FontWeight="SemiBold"
                                               TextWrapping="Wrap" />
                                </Border>
                                <TextBlock Text="Всё автоматически после настройки"
                                           Opacity="0.7"
                                           FontSize="12"
                                           HorizontalAlignment="Center"
                                           TextWrapping="Wrap"
                                           TextAlignment="Center" />
                            </StackPanel>
                        </Panel>

                        <Panel IsVisible="{Binding IsFinishVisible}">
                            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="12">
                                <Border Width="72" Height="72" CornerRadius="36" Background="#334CAF50">
                                    <Border.Styles>
                                        <Style Selector="Border">
                                            <Style.Animations>
                                                <Animation Duration="0:0:1.6" IterationCount="Infinite">
                                                    <KeyFrame Cue="0%">
                                                        <Setter Property="Opacity" Value="0.7" />
                                                    </KeyFrame>
                                                    <KeyFrame Cue="50%">
                                                        <Setter Property="Opacity" Value="1" />
                                                    </KeyFrame>
                                                    <KeyFrame Cue="100%">
                                                        <Setter Property="Opacity" Value="0.7" />
                                                    </KeyFrame>
                                                </Animation>
                                            </Style.Animations>
                                        </Style>
                                    </Border.Styles>
                                    <TextBlock Text="✓"
                                               FontSize="32"
                                               FontWeight="Bold"
                                               Foreground="#81C784"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center" />
                                </Border>
                                <TextBlock Text="Можно начинать"
                                           FontWeight="SemiBold"
                                           HorizontalAlignment="Center" />
                                <TextBlock Text="Не забудьте нажать «Сохранить»"
                                           Opacity="0.7"
                                           FontSize="12"
                                           HorizontalAlignment="Center" />
                            </StackPanel>
                        </Panel>
                    </Panel>
                </Border>
            </Grid>
        </Border>

        <Grid Grid.Row="3" ColumnDefinitions="Auto,*,Auto">
            <Button Grid.Column="0"
                    Content="Назад"
                    Command="{Binding PreviousCommand}"
                    MinWidth="120"
                    MinHeight="34"
                    Padding="16,8"
                    FontSize="{DynamicResource SectionHeaderFontSize}"
                    HorizontalContentAlignment="Center"
                    VerticalContentAlignment="Center" />
            <Button Grid.Column="2"
                    Content="{Binding NextButtonText}"
                    Command="{Binding NextCommand}"
                    MinWidth="120"
                    MinHeight="34"
                    Padding="16,8"
                    Background="{DynamicResource ButtonGreen}"
                    Foreground="{DynamicResource ButtonGreenText}"
                    FontSize="{DynamicResource SectionHeaderFontSize}"
                    HorizontalContentAlignment="Center"
                    VerticalContentAlignment="Center">
                <Button.Styles>
                    <Style Selector="Button:pointerover">
                        <Setter Property="Background" Value="{DynamicResource ButtonGreenHover}" />
                    </Style>
                    <Style Selector="Button:pressed">
                        <Setter Property="Background" Value="{DynamicResource ButtonGreenPressed}" />
                    </Style>
                </Button.Styles>
            </Button>
        </Grid>
    </Grid>
</Window>
