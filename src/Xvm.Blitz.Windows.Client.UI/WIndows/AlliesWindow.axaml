<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Xvm.Blitz.Windows.Client.UI.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:converters="using:Xvm.Blitz.Windows.Client.UI.Converters"
        xmlns:models="clr-namespace:Xvm.Blitz.Windows.Client.UI.ViewModels.Models"
        mc:Ignorable="d" d:DesignWidth="350" d:DesignHeight="400"
        x:Class="Xvm.Blitz.Windows.Client.UI.Windows.AlliesWindow"
        x:DataType="vm:BattleStatisticsViewModel"
        Icon="/Assets/xvm.ico"
        Title=""
        Topmost="True"
        Width="{Binding OverlayMinWidth}"
        SizeToContent="Height"
        WindowStartupLocation="CenterScreen"
        SystemDecorations="None"
        Background="Transparent"
        PointerPressed="Window_PointerPressed">

    <Window.ContextMenu>
        <ContextMenu>
            <MenuItem Header="Скрыть панели" Click="HidePanels_Click" />
        </ContextMenu>
    </Window.ContextMenu>

    <Window.Resources>
        <converters:BattlesToKiloConverter x:Key="BattlesToKiloConverter" />
    </Window.Resources>

    <Grid>
        <Border Background="#80000000" CornerRadius="5" ClipToBounds="True">
            <Grid RowDefinitions="Auto,*,Auto">
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" MaxHeight="500">
                    <ItemsControl x:Name="ItemsRoot" ItemsSource="{Binding Allies}"
                                  Background="Transparent"
                                  HorizontalAlignment="Stretch"
                                  Grid.IsSharedSizeScope="True"
                                  Padding="8,8,8,8"
                                  FontSize="{Binding OverlayFontSize}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Spacing="4" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid HorizontalAlignment="Stretch">
                                    <Grid.Transitions>
                                        <Transitions>
                                            <DoubleTransition Property="Opacity" Duration="0:0:0.4"
                                                              Easing="CubicEaseOut" />
                                        </Transitions>
                                    </Grid.Transitions>

                                    <Border CornerRadius="3"
                                            HorizontalAlignment="Stretch"
                                            BorderThickness="{Binding Players.Length, Converter={StaticResource CountToBorderThicknessConverter}}"
                                            BorderBrush="White">
                                        <Border.Transitions>
                                            <Transitions>
                                                <DoubleTransition Property="Opacity" Duration="0:0:0.4"
                                                                  Easing="CubicEaseOut" />
                                            </Transitions>
                                        </Border.Transitions>

                                        <ItemsControl ItemsSource="{Binding Players}">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <StackPanel
                                                        Spacing="{Binding Players.Length, Converter={StaticResource CountToSpacingConverter}}" />
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate x:DataType="models:PlayerViewModel">
                                                    <Grid HorizontalAlignment="Stretch" ColumnSpacing="4">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*" MinWidth="40" />
                                                            <ColumnDefinition Width="*" MinWidth="36" />
                                                            <ColumnDefinition Width="Auto" SharedSizeGroup="BattlesColumn" />
                                                            <ColumnDefinition Width="Auto" SharedSizeGroup="WinRateColumn" />
                                                        </Grid.ColumnDefinitions>

                                                        <TextBlock Grid.Column="0"
                                                                   Text="{Binding NicknameWithClanTag}"
                                                                   Margin="5,2,2,2"
                                                                   VerticalAlignment="Center"
                                                                   TextTrimming="CharacterEllipsis"
                                                                   TextWrapping="NoWrap"
                                                                   IsVisible="{Binding !IsTableNumberMissing}" />
                                                        <TextBlock Grid.Column="0"
                                                                   Text="—"
                                                                   Margin="5,2,2,2"
                                                                   Foreground="White"
                                                                   VerticalAlignment="Center"
                                                                   IsVisible="{Binding IsTableNumberMissing}" />

                                                        <TextBlock Grid.Column="1"
                                                                   Text="{Binding Tank}"
                                                                   Margin="2,2,4,2"
                                                                   HorizontalAlignment="Right"
                                                                   VerticalAlignment="Center"
                                                                   TextTrimming="CharacterEllipsis"
                                                                   TextWrapping="NoWrap"
                                                                   IsVisible="{Binding !IsTableNumberMissing}" />
                                                        <TextBlock Grid.Column="1"
                                                                   Text="—"
                                                                   Margin="2,2,4,2"
                                                                   Foreground="White"
                                                                   HorizontalAlignment="Right"
                                                                   VerticalAlignment="Center"
                                                                   IsVisible="{Binding IsTableNumberMissing}" />

                                                        <TextBlock Grid.Column="2"
                                                                   Text="{Binding NumberOfBattles, Converter={StaticResource BattlesToKiloConverter}}"
                                                                   Margin="4,2,4,2"
                                                                   HorizontalAlignment="Right"
                                                                   VerticalAlignment="Center"
                                                                   TextTrimming="CharacterEllipsis"
                                                                   TextWrapping="NoWrap"
                                                                   IsVisible="{Binding !IsTableNumberMissing}" />
                                                        <TextBlock Grid.Column="2"
                                                                   Text="—"
                                                                   Margin="4,2,4,2"
                                                                   Foreground="White"
                                                                   HorizontalAlignment="Right"
                                                                   VerticalAlignment="Center"
                                                                   IsVisible="{Binding IsTableNumberMissing}" />

                                                        <TextBlock Grid.Column="3"
                                                                   Text="{Binding WinRate, StringFormat={}{0:F2}%}"
                                                                   Margin="4,2,5,2"
                                                                   Foreground="{Binding WinRate, Converter={StaticResource WinRateToBackgroundConverter}}"
                                                                   VerticalAlignment="Center"
                                                                   TextTrimming="CharacterEllipsis"
                                                                   TextWrapping="NoWrap"
                                                                   IsVisible="{Binding !IsTableNumberMissing}" />
                                                        <TextBlock Grid.Column="3"
                                                                   Text="—"
                                                                   Margin="4,2,5,2"
                                                                   Foreground="White"
                                                                   VerticalAlignment="Center"
                                                                   IsVisible="{Binding IsTableNumberMissing}" />
                                                    </Grid>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </Border>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Border>
        <Border Width="18"
                Height="18"
                Margin="0,0,2,2"
                HorizontalAlignment="Right"
                VerticalAlignment="Bottom"
                Background="#99FFFFFF"
                CornerRadius="3"
                Cursor="BottomRightCorner"
                IsVisible="{Binding IsDisplayConfigurationMode}"
                PointerPressed="ResizeHandle_PointerPressed" />
    </Grid>
</Window>
