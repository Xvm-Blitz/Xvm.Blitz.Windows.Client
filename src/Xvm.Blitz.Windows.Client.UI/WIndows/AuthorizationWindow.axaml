<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="using:Xvm.Blitz.Windows.Client.UI.ViewModels"
        mc:Ignorable="d" d:DesignWidth="600" d:DesignHeight="500"
        x:Class="Xvm.Blitz.Windows.Client.UI.Windows.AuthorizationWindow"
        x:DataType="vm:AuthorizationViewModel"
        x:Name="Window"
        Title="Авторизация и статистика использования"
        Icon="/Assets/xvm.ico"
        Width="600" Height="500"
        WindowStartupLocation="CenterScreen"
        CanResize="False">

    <Grid>
        <Grid Margin="20" RowDefinitions="Auto,*,Auto">
            <TextBlock Grid.Row="0"
                       Text="Авторизация и статистика использования"
                       FontSize="{DynamicResource MainTitleFontSize}"
                       FontWeight="Bold"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,20" />
            <StackPanel Grid.Row="1"
                        Spacing="15"
                        IsVisible="{Binding !IsApiKeyExists}">
                <TextBlock Text="Введите API ключ"
                           FontSize="{DynamicResource SectionHeaderFontSize}"
                           FontWeight="SemiBold"
                           HorizontalAlignment="Center" />

                <TextBox Text="{Binding ApiKey}"
                         Watermark="API ключ"
                         FontSize="{DynamicResource NormalFontSize}"
                         IsEnabled="{Binding !IsLoading}"
                         HorizontalAlignment="Stretch"
                         Margin="0,10,0,10" />

                <Button Content="Войти"
                        Command="{Binding LoginCommand}"
                        CommandParameter="{Binding ElementName=Window}"
                        IsEnabled="{Binding !IsLoading}"
                        FontSize="{DynamicResource NormalFontSize}"
                        HorizontalAlignment="Stretch"
                        Margin="0,10,0,10" />

                <ProgressBar IsIndeterminate="True"
                             IsVisible="{Binding IsLoading}"
                             Margin="0,10,0,0" />
            </StackPanel>
            <StackPanel Grid.Row="1"
                        Spacing="15"
                        IsVisible="{Binding IsApiKeyExists}">

                <StackPanel Spacing="15" IsVisible="{Binding IsQuotaAvailable}">
                    <Border Background="Gray"
                            CornerRadius="8"
                            Padding="15">
                        <StackPanel Spacing="10">
                            <TextBlock Text="Остаток"
                                       FontSize="{DynamicResource SectionHeaderFontSize}"
                                       FontWeight="SemiBold" />
                            <TextBlock Text="{Binding QuotaStatusText}"
                                       FontSize="{DynamicResource NormalFontSize}"
                                       FontWeight="Medium" />
                            <ProgressBar Value="{Binding UsagePercentage}"
                                         Maximum="100"
                                         Height="20"
                                         Foreground="{Binding UsagePercentage, Converter={StaticResource QuotaProgressColorConverter}}" />
                        </StackPanel>
                    </Border>

                    <Border Background="DarkCyan"
                            CornerRadius="8"
                            Padding="15">
                        <StackPanel Spacing="8">
                            <TextBlock Text="Период действия"
                                       FontSize="{DynamicResource SectionHeaderFontSize}"
                                       FontWeight="SemiBold" />

                            <TextBlock Text="{Binding FormattedPeriod}"
                                       FontSize="{DynamicResource NormalFontSize}" />

                            <TextBlock Text="{Binding RemainingTimeText}"
                                       FontSize="{DynamicResource SmallNoteFontSize}"
                                       FontStyle="Italic" />
                        </StackPanel>
                    </Border>

                    <Border Background="Orange"
                            CornerRadius="8"
                            Padding="15"
                            IsVisible="{Binding IsQuotaLow}">
                        <StackPanel Spacing="5">
                            <TextBlock Text="Ипользовано более чем на 80%."
                                       FontSize="{DynamicResource SmallNoteFontSize}"
                                       Foreground="White"
                                       TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>

                    <Border Background="Red"
                            CornerRadius="8"
                            Padding="15"
                            IsVisible="{Binding IsQuotaCritical}">
                        <StackPanel Spacing="5">
                            <TextBlock Text="Ипользовано более чем на 95%."
                                       FontSize="{DynamicResource SmallNoteFontSize}"
                                       Foreground="White"
                                       TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>

                    <Button Content="Сменить API ключ"
                            Command="{Binding LogoutCommand}"
                            IsEnabled="{Binding !IsLoading}"
                            FontSize="{DynamicResource NormalFontSize}"
                            HorizontalAlignment="Stretch"
                            Margin="0,15,0,0" />
                </StackPanel>

                <StackPanel IsVisible="{Binding !IsQuotaAvailable}"
                            VerticalAlignment="Center"
                            HorizontalAlignment="Center"
                            Spacing="10">
                    <TextBlock Text="📊"
                               FontSize="48"
                               HorizontalAlignment="Center" />
                    <TextBlock Text="{Binding QuotaStatusText}"
                               FontSize="{DynamicResource SectionHeaderFontSize}"
                               HorizontalAlignment="Center" />
                    <TextBlock Text="Проверьте корректность API ключа"
                               FontSize="{DynamicResource SmallNoteFontSize}"
                               Foreground="Gray"
                               HorizontalAlignment="Center" />

                    <Button Content="Выйти"
                            Command="{Binding LogoutCommand}"
                            IsEnabled="{Binding !IsLoading}"
                            FontSize="{DynamicResource NormalFontSize}"
                            HorizontalAlignment="Center"
                            Margin="0,15,0,0" />
                </StackPanel>
            </StackPanel>

            <TextBlock Grid.Row="2"
                       Text="{Binding StatusMessage}"
                       HorizontalAlignment="Center"
                       FontSize="{DynamicResource SmallNoteFontSize}"
                       Foreground="Gray"
                       Margin="0,10,0,10"
                       IsVisible="{Binding StatusMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
        </Grid>
        <Border IsVisible="{Binding IsConfirmationVisible}"
                Background="#80000000"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Stretch">
            <Border Background="#2D2D30"
                    BorderBrush="#3F3F46"
                    BorderThickness="2"
                    CornerRadius="10"
                    Padding="35"
                    MinWidth="500"
                    MaxWidth="650"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    BoxShadow="0 4 20 0 #60000000">
                <StackPanel Spacing="20">
                    <TextBlock Text="⚠️"
                               FontSize="48"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,10" />

                    <TextBlock Text="Подтверждение смены API ключа"
                               FontSize="{DynamicResource SectionHeaderFontSize}"
                               FontWeight="Bold"
                               Foreground="White"
                               HorizontalAlignment="Center"
                               TextAlignment="Center" />

                    <TextBlock
                        Text="Вы уверены, что хотите сменить API ключ? Текущий ключ будет утерян, если Вы не сохранили его предварительно."
                        FontSize="{DynamicResource NormalFontSize}"
                        Foreground="#E0E0E0"
                        TextWrapping="Wrap"
                        HorizontalAlignment="Stretch"
                        TextAlignment="Center"
                        Padding="5,5,5,5"
                        Margin="5,10,5,20" />

                    <StackPanel Orientation="Horizontal"
                                Spacing="15"
                                HorizontalAlignment="Center">
                        <Button Content="Продолжить"
                                Command="{Binding ConfirmLogoutCommand}"
                                FontSize="{DynamicResource NormalFontSize}"
                                Background="#D32F2F"
                                Foreground="White"
                                HorizontalAlignment="Center"
                                HorizontalContentAlignment="Center"
                                VerticalContentAlignment="Center"
                                FontWeight="SemiBold"
                                Padding="20,10"
                                MinWidth="120"
                                CornerRadius="5">
                            <Button.Styles>
                                <Style Selector="Button:pointerover">
                                    <Setter Property="Background" Value="#F44336" />
                                </Style>
                                <Style Selector="Button:pressed">
                                    <Setter Property="Background" Value="#B71C1C" />
                                </Style>
                            </Button.Styles>
                        </Button>

                        <Button Content="Отмена"
                                Command="{Binding CancelLogoutCommand}"
                                FontSize="{DynamicResource NormalFontSize}"
                                Background="#424242"
                                Foreground="White"
                                FontWeight="SemiBold"
                                HorizontalAlignment="Center"
                                HorizontalContentAlignment="Center"
                                VerticalContentAlignment="Center"
                                Padding="20,10"
                                MinWidth="120"
                                CornerRadius="5">
                            <Button.Styles>
                                <Style Selector="Button:pointerover">
                                    <Setter Property="Background" Value="#616161" />
                                </Style>
                                <Style Selector="Button:pressed">
                                    <Setter Property="Background" Value="#212121" />
                                </Style>
                            </Button.Styles>
                        </Button>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Border>
    </Grid>
</Window>